# =============================================================================
# Datanalys - Production Environment Variables
# Copy this file to .env.prod and update ALL values before deployment
# =============================================================================

# -----------------------------------------------------------------------------
# Django Settings
# -----------------------------------------------------------------------------
# IMPORTANT: Generate a new secret key for production!
# Run: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-change-this-in-production

# Debug mode (MUST be False in production)
DEBUG=False

# Allowed hosts - replace with your server IP/domain
ALLOWED_HOSTS=localhost,127.0.0.1,YOUR_SERVER_IP

# CORS - replace with your server IP/domain
CORS_ALLOWED_ORIGINS=http://YOUR_SERVER_IP,http://localhost

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_NAME=datanalys
DB_USER=datanalys
DB_PASSWORD=your_secure_database_password_here
DB_HOST=db
DB_PORT=5432

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Admin User (created on first startup)
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your_secure_admin_password_here

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
VITE_API_URL=/api/v1/analytics

# -----------------------------------------------------------------------------
# PandaScore API (optional - fallback for completed game data)
# Get your key at https://pandascore.co/
# -----------------------------------------------------------------------------
PANDASCORE_API_KEY=your-pandascore-api-key-here

# -----------------------------------------------------------------------------
# Data Import
# -----------------------------------------------------------------------------
AUTO_UPDATE_ORACLE_DATA=false
