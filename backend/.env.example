# =============================================================================
# Datanalys - Development Environment Variables
# Copy this file to .env and update values as needed
# =============================================================================

# Django
SECRET_KEY=local-dev-secret-key-change-me
DEBUG=True

# Database (PostgreSQL via Docker)
DATABASE_URL=postgres://datanalys:datanalys@db:5432/datanalys
DB_NAME=datanalys
DB_USER=datanalys
DB_PASSWORD=datanalys
DB_HOST=db
DB_PORT=5432

# CORS / Hosts
ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Data import
AUTO_UPDATE_ORACLE_DATA=true
ENABLE_SCHEDULER=true

# PandaScore API (optional - used as fallback for completed game data)
# Get your key at https://pandascore.co/
PANDASCORE_API_KEY=your-pandascore-api-key-here
